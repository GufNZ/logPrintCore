resharper_web_config_redundant_location_tag_highlighting = hint
resharper_web_ignored_path_highlighting = hint
resharper_wrong_indent_size_highlighting = error
resharper_wrong_metadata_use_highlighting = warning
resharper_xaml_ignored_path_highlighting_highlighting = suggestion

# These settings must match terraform fmt
[*.tf]
indent_size = 2
indent_style = space

[*.yaml]
indent_style = space
trim_trailing_whitespace = false

[*.yml]
indent_size = 4
indent_style = space
